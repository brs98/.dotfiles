#!/usr/bin/env bash

set -euo pipefail
umask 077

usage() {
  cat <<'EOF'
Usage: setup-cliproxyapi [provider]

Install and configure CLIProxyAPI as a localhost-only Homebrew service.
OAuth credentials and the generated client key stay in ~/.cli-proxy-api.

Providers:
  codex        OpenAI Codex OAuth
  claude       Anthropic Claude OAuth
  antigravity  Google Antigravity OAuth
  kimi         Kimi OAuth
  xai          xAI OAuth
EOF
}

if (( $# > 1 )); then
  echo "Expected at most one provider argument." >&2
  usage >&2
  exit 2
fi

provider="${1:-}"
case "$provider" in
  ""|codex|claude|antigravity|kimi|xai) ;;
  -h|--help)
    usage
    exit 0
    ;;
  *)
    echo "Unknown provider: $provider" >&2
    usage >&2
    exit 2
    ;;
esac

if [[ "${OSTYPE:-}" != darwin* ]]; then
  echo "setup-cliproxyapi currently supports macOS only." >&2
  exit 1
fi

if ! command -v brew >/dev/null 2>&1; then
  echo "Homebrew is required: https://brew.sh" >&2
  exit 1
fi

if ! brew list --versions cliproxyapi >/dev/null 2>&1; then
  brew install cliproxyapi
elif [[ -n "$(brew outdated --quiet cliproxyapi 2>/dev/null)" ]]; then
  brew upgrade cliproxyapi
fi

if [[ -n "${CLIPROXYAPI_HOME:-}" ]]; then
  config_dir="$CLIPROXYAPI_HOME"
else
  config_dir="$HOME/.cli-proxy-api"
fi

if [[ "$config_dir" != /* ]]; then
  echo "CLIPROXYAPI_HOME must be an absolute path: $config_dir" >&2
  exit 1
fi

yaml_config_dir="${config_dir//\\/\\\\}"
yaml_config_dir="${yaml_config_dir//\"/\\\"}"
config_file="$config_dir/config.yaml"
key_file="$config_dir/api-key"
brew_prefix="$(brew --prefix)"
cliproxy_bin="$(brew --prefix cliproxyapi)/bin/cliproxyapi"
service_config="$brew_prefix/etc/cliproxyapi.conf"
generated_marker="# Generated by setup-cliproxyapi. OAuth tokens and the API key are local only."

mkdir -p "$config_dir"
chmod 700 "$config_dir"

if [[ -e "$config_file" ]] && ! grep -Fqx "$generated_marker" "$config_file"; then
  echo "Refusing to replace or start an unmanaged config: $config_file" >&2
  echo "Move it aside or configure and start CLIProxyAPI manually." >&2
  exit 1
fi

if [[ ! -e "$key_file" ]]; then
  if [[ -e "$config_file" ]]; then
    echo "Missing API key file for managed config: $key_file" >&2
    exit 1
  fi
  openssl rand -hex 32 > "$key_file"
fi

chmod 600 "$key_file"
api_key="$(<"$key_file")"
if [[ ! "$api_key" =~ ^[[:xdigit:]]{64}$ ]]; then
  echo "Expected a 64-character hexadecimal API key in $key_file" >&2
  exit 1
fi

temp_config="$(mktemp "$config_dir/config.yaml.tmp.XXXXXX")"
chmod 600 "$temp_config"

cat > "$temp_config" <<EOF
$generated_marker
# This file is fully managed; rerunning the setup replaces local edits.
host: "127.0.0.1"
port: 8317

tls:
  enable: false

remote-management:
  allow-remote: false
  secret-key: ""
  disable-control-panel: true

auth-dir: "$yaml_config_dir"

api-keys:
  - "$api_key"

debug: false
logging-to-file: false
usage-statistics-enabled: false
ws-auth: true
EOF

if [[ -e "$config_file" ]] && cmp -s "$temp_config" "$config_file"; then
  rm -f "$temp_config"
  chmod 600 "$config_file"
  echo "Preserving existing $config_file"
else
  mv "$temp_config" "$config_file"
  echo "Created or updated $config_file"
fi

if [[ -L "$service_config" ]] && [[ "$(readlink "$service_config")" == "$config_file" ]]; then
  :
else
  if [[ -e "$service_config" || -L "$service_config" ]]; then
    backup="$service_config.bak.$(date +%Y%m%d%H%M%S)"
    mv "$service_config" "$backup"
    echo "Backed up Homebrew's config to $backup"
  fi
  ln -s "$config_file" "$service_config"
fi

brew services restart cliproxyapi >/dev/null

http_status=""
for _ in {1..20}; do
  http_status="$(
    curl --silent --show-error --output /dev/null --write-out '%{http_code}' \
      --connect-timeout 1 --max-time 2 \
      --header "Authorization: Bearer $api_key" \
      http://127.0.0.1:8317/v1/models 2>/dev/null || true
  )"
  [[ "$http_status" == "200" ]] && break
  sleep 0.25
done

if [[ "$http_status" != "200" ]]; then
  echo "CLIProxyAPI did not pass its authenticated health check (HTTP ${http_status:-none})." >&2
  echo "Inspect it with: brew services info cliproxyapi" >&2
  exit 1
fi

unauthenticated_status="$(
  curl --silent --show-error --output /dev/null --write-out '%{http_code}' \
    --connect-timeout 1 --max-time 2 \
    http://127.0.0.1:8317/v1/models 2>/dev/null || true
)"
if [[ "$unauthenticated_status" != "401" ]]; then
  echo "CLIProxyAPI did not reject an unauthenticated request (HTTP ${unauthenticated_status:-none})." >&2
  exit 1
fi

echo "CLIProxyAPI is listening on http://127.0.0.1:8317 (authenticated HTTP 200; anonymous HTTP 401)"

if [[ -n "$provider" ]]; then
  login_flag="--${provider}-login"
  "$cliproxy_bin" --config "$config_file" "$login_flag"
  echo "OAuth command finished. Confirm the output above says authentication succeeded;"
  echo "CLIProxyAPI may return exit 0 for some provider-side authentication failures."
else
  echo "Run setup-cliproxyapi <provider> to add an OAuth account."
fi

if [[ -f "$key_file" ]]; then
  echo "Client API key: $key_file"
else
  echo "Use an entry from api-keys in $config_file when configuring clients."
fi
