*.undodir/
shared/.claude/

# Node/Turbo dependencies and caches for the isolated Pi config monorepo
.turbo/
shared/stow/pi/.pi/agent/node_modules/
shared/stow/pi/.pi/agent/.turbo/
shared/stow/pi/.pi/agent/packages/*/.turbo/
shared/stow/pi/.pi/agent/extensions/node_modules/
shared/stow/pi/.pi/agent/extensions/.turbo/
shared/stow/pi/.pi/agent/extensions/coverage/

# Runtime symlink managed by omarchy theme-set hook / install.sh
shared/stow/nvim/.config/nvim/lua/plugins/theme.lua

# Starship palette is rewritten by ricekit — keep stow symlink but don't track contents
shared/stow/starship/

# Pebbles issue state is intentionally tracked for simple cross-machine sync.
.pebbles/*
!.pebbles/
!.pebbles/db.sqlite
