#!/bin/bash

# CLI script to checkout an existing remote branch as a new git worktree and wezterm workspace
# Usage: checkout <branch-name> [-f|--frontend] [-b|--backend] [--cwd <directory>]

set -e

# Repository paths
FRONTEND_REPO="~/work/fluid-mono-with-backend/fluid-mono.git"
BACKEND_REPO="~/work/fluid-mono-with-backend/fluid.git"

BRANCH_NAME=""
CWD="$FRONTEND_REPO"
DEFAULT_BRANCH="main"

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -f|--frontend)
            CWD="$FRONTEND_REPO"
            DEFAULT_BRANCH="main"
            shift
            ;;
        -b|--backend)
            CWD="$BACKEND_REPO"
            DEFAULT_BRANCH="master"
            shift
            ;;
        --cwd)
            CWD="$2"
            shift 2
            ;;
        *)
            if [ -z "$BRANCH_NAME" ]; then
                BRANCH_NAME="$1"
            else
                echo "Error: Unknown argument '$1'"
                exit 1
            fi
            shift
            ;;
    esac
done

if [ -z "$BRANCH_NAME" ]; then
    echo "Usage: checkout <branch-name> [-f|--frontend] [-b|--backend] [--cwd <directory>]"
    echo ""
    echo "Options:"
    echo "  -f, --frontend    Use frontend repo (fluid-mono.git) [default]"
    echo "  -b, --backend     Use backend repo (fluid.git)"
    echo "  --cwd <dir>       Use custom directory"
    echo ""
    echo "Examples:"
    echo "  checkout brandon/feature-1           # Checks out from frontend repo (default)"
    echo "  checkout brandon/feature-1 -b        # Checks out from backend repo"
    echo "  checkout brandon/feature-1 --backend # Checks out from backend repo"
    echo "  checkout brandon/feature-1 --cwd ~/my-project"
    exit 1
fi

# Run the wezterm command that creates workspace, worktree, and runs setup commands
wezterm cli spawn --cwd "$CWD" --new-window --workspace "$BRANCH_NAME" &&
PANE_ID=$(wezterm cli list --format json | jq -r '.[] | select(.workspace == "'$BRANCH_NAME'") | .pane_id' | head -n1) &&
osascript -e 'tell application "WezTerm" to activate' &&
osascript -e 'tell application "System Events" to keystroke "s" using {command down, option down}' &&
osascript -e 'tell application "System Events" to keystroke "'$BRANCH_NAME'"' &&
osascript -e 'tell application "System Events" to key code 36' &&
wezterm cli send-text --pane-id "$PANE_ID" "cd $CWD/$DEFAULT_BRANCH && git fetch origin '+refs/heads/*:refs/remotes/origin/*' && cd $CWD && git worktree add $BRANCH_NAME origin/$BRANCH_NAME && cd $BRANCH_NAME && git checkout -b $BRANCH_NAME && git branch -u origin/$BRANCH_NAME"

echo "Created wezterm workspace '$BRANCH_NAME' with git worktree tracking origin/$BRANCH_NAME"
